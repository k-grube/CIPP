CIPP_API_URL=https://your-cipp-instance.azurewebsites.net
CIPP_CLIENT_ID=your-azure-ad-client-id
CIPP_CLIENT_SECRET=your-client-secret
CIPP_TENANT_ID=your-azure-ad-tenant-id
# Comma-separated list of tenant domains. The schema generator (test:api:update)
# samples all listed tenants to build comprehensive schemas. The test runner
# (test:api) validates against the first tenant only.
CIPP_TENANT_FILTER=yourtenant.onmicrosoft.com,optional-second-tenant.onmicrosoft.com
# Number of API endpoints to test in parallel (default: 5)
CIPP_API_CONCURRENCY=5
